// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch",
      "label": "Start Watchers",
      "isBackground": true,
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "never"
      },
      "problemMatcher": [
        "$tsc-watch",
        {
          "owner": "esbuild",
          "background": {
            "activeOnStart": true,
            "beginsPattern": "^\\[watch\\] build started$",
            "endsPattern": "^\\[watch\\] build finished$"
          },
          "pattern": {
            "regexp": "✘ \\[ERROR\\] (.+)$",
            "message": 1
          }
        }
      ]
    }
  ]
}