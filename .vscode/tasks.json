// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[watch\\] build started",
          "endsPattern": "\\[watch\\] build finished"
        },
        "pattern": {
          "regexp": "✘ \\[ERROR\\] (.+)$",
          "message": 1
        }
      },
      "presentation": {
        "reveal": "never"
      },
      "group": "build"
    },
    {
      "type": "shell",
      "label": "vite-build",
      "command": "./node_modules/.bin/vite",
      "args": ["build"],
      "group": "build"
    },
    {
      "label": "Build All",
      "dependsOrder": "sequence",
      "dependsOn": ["vite-build", "npm: watch"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
